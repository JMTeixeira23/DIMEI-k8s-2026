    {
      "mode": "managed",
      "type": "helm_release",
      "name": "kyverno",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "kyverno",
            "cleanup_on_fail": false,
            "create_namespace": true,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "kyverno",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "v1.11.4",
                "chart": "kyverno",
                "first_deployed": 1772881130,
                "last_deployed": 1772881130,
                "name": "kyverno",
                "namespace": "kyverno",
                "notes": "Chart version: 3.1.4\nKyverno version: v1.11.4\n\nThank you for installing kyverno! Your release is named kyverno.\n\nThe following components have been installed in your cluster:\n- CRDs\n- Admission controller\n- Reports controller\n- Cleanup controller\n- Background controller\n\n\n⚠️  WARNING: Setting the admission controller replica count below 3 means Kyverno is not running in high availability mode.\n\n💡 Note: There is a trade-off when deciding which approach to take regarding Namespace exclusions. Please see the documentation at https://kyverno.io/docs/installation/#security-vs-operability to understand the risks.\n",
                "revision": 1,
                "values": "{\"admissionController\":{\"replicas\":1},\"backgroundController\":{\"enabled\":true},\"cleanupController\":{\"enabled\":true},\"config\":{\"webhooks\":[{\"name\":\"mutating-webhook-cfg\",\"timeoutSeconds\":15},{\"name\":\"validating-webhook-cfg\",\"timeoutSeconds\":15}]},\"failurePolicy\":\"Ignore\",\"logLevel\":\"info\",\"metricsService\":{\"create\":true,\"port\":8000},\"replicaCount\":1,\"reportsController\":{\"enabled\":true},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}}}",
                "version": "3.1.4"
              }
            ],
            "name": "kyverno",
            "namespace": "kyverno",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://kyverno.github.io/kyverno/",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "# helm/kyverno-values.yaml\n# Cloud-agnostic Kyverno configuration.\n# Applied to both EKS (now) and AKS (future) using the same file.\n# The only cloud-specific details are in the ClusterPolicy YAMLs (Phase 3),\n# not here — specifically the registry URL prefix and OIDC issuer subject.\n\nreplicaCount: 1\n\nresources:\n  limits:\n    cpu: 500m\n    memory: 512Mi\n  requests:\n    cpu: 100m\n    memory: 256Mi\n\nadmissionController:\n  replicas: 1\n\n# Background controller scans existing resources periodically\nbackgroundController:\n  enabled: true\n\n# Reports controller writes PolicyReport objects — used in Phase 3 audit mode\nreportsController:\n  enabled: true\n\ncleanupController:\n  enabled: true\n\n# Fail-open: if Kyverno itself crashes, pods are still admitted.\n# Thesis note: discuss fail-open vs fail-closed trade-offs in Chapter 5.\n# Switch to Fail for hardened production deployments.\nfailurePolicy: Ignore\n\n# Log level: use debug during Phase 3 policy development, then revert to info\nlogLevel: info\n\n# Expose Prometheus metrics — consumed in Phase 4/5 latency measurements.\n# Enable serviceMonitor if Prometheus Operator is installed.\nmetricsService:\n  create: true\n  port: 8000\n\nconfig:\n  webhooks:\n    - name: mutating-webhook-cfg\n      timeoutSeconds: 15\n    - name: validating-webhook-cfg\n      timeoutSeconds: 15\n"
            ],
            "verify": false,
            "version": "3.1.4",
            "wait": true,
            "wait_for_jobs": false
          },
